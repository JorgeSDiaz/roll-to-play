---
import AppLayout from '../layouts/AppLayout.astro';
import HeaderControls from '../api-key/components/HeaderControls';
import SearchPanel from '../search/components/SearchPanel';
import GameList from '../game-list/components/GameList';
import MainArea from '../shuffle/components/MainArea';
import SidebarToggle from '../shared/ui/SidebarToggle';
---

<AppLayout title="RollToPlay">
  <!-- Header -->
  <header class="h-14 flex items-center justify-between px-4 md:px-6 border-b border-[var(--color-border-subtle)] sticky top-0 z-10 bg-[var(--color-bg-base)]">
    <div class="flex items-center gap-3">
      <SidebarToggle client:load />
      <span class="text-2xl font-bold tracking-tight text-[var(--color-text-primary)]">
        RollToPlay
      </span>
    </div>
    <HeaderControls client:load />
  </header>

  <!-- Layout principal -->
  <div class="flex min-h-[calc(100dvh-3.5rem)] relative">

    <!-- Overlay mobile -->
    <div
      id="sidebar-overlay"
      class="fixed inset-0 z-30 bg-black/50 hidden md:hidden"
      aria-hidden="true"
    />

    <!-- Sidebar -->
    <aside
      id="sidebar"
      class="
        fixed inset-y-0 left-0 z-40 w-80 pt-14
        bg-[var(--color-bg-base)] border-r border-[var(--color-border-subtle)]
        overflow-y-auto
        transform -translate-x-full transition-transform duration-300 ease-out
        md:relative md:inset-auto md:translate-x-0 md:pt-0 md:shrink-0 md:block
      "
      aria-label="Panel lateral"
    >
      <div class="p-6 space-y-4">
        <SearchPanel client:load />
        <div class="border-t border-[var(--color-border-subtle)]" />
        <GameList client:load />
      </div>
    </aside>

    <!-- Área principal -->
    <main class="flex-1 flex flex-col items-center justify-center p-8">
      <MainArea client:load />
    </main>
  </div>
</AppLayout>

<script>
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    sidebar?.classList.add('translate-x-0');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    sidebar?.classList.remove('translate-x-0');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  overlay?.addEventListener('click', closeSidebar);
  document.addEventListener('rtp:open-sidebar', openSidebar);
  document.addEventListener('rtp:close-sidebar', closeSidebar);
</script>
